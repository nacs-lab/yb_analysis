# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Packaging / build artifacts ---
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# --- Test / type / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*~

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Local runtime artifacts / data (none of these are tracked) ---
# The dashboard/proxy IPC pickle (normally lives in the temp dir, but guard anyway)
yb_dash_slm.pkl
*.pkl
*.log
# Bulk scan data — keep out of the code repo (tracked .csv/.json/.zip are NOT matched)
*.h5
*.hdf5
*.mat
*.npy
*.npz
